# Snyk (https://snyk.io) policy file
version: v1.28.0

# Test fixtures contain mock/fake credentials used only for assertions.
# These are not real secrets and must not block scans.
ignore:
  'python/NoHardcodedCredentials/test':
    - '**/tests/**':
        reason: Test fixtures with mock credentials for testing only
        expires: never
  'python/HardcodedPassword':
    - '**/tests/**':
        reason: Test fixtures with mock credentials for testing only
        expires: never
  'python/HardcodedNonCryptoSecret':
    - '**/tests/**':
        reason: Test fixtures with mock credentials for testing only
        expires: never
