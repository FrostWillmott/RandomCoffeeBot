# Application
DEBUG=false
LOG_LEVEL=WARNING
SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# Domain
DOMAIN=api.randomcoffee.example.com

# Telegram
TELEGRAM_BOT_TOKEN=
CHANNEL_ID=

# Database
POSTGRES_USER=randomcoffee
POSTGRES_PASSWORD=  # Generate strong password
POSTGRES_DB=randomcoffee
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis
REDIS_PASSWORD=  # Generate strong password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Celery
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# Mail (Production SMTP)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@randomcoffee.example.com
MAIL_TLS=true

# Flower
FLOWER_USER=admin
FLOWER_PASSWORD=  # Generate strong password

# Traefik
ACME_EMAIL=admin@example.com
# Generate with: htpasswd -nb admin password | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=

# Image
IMAGE_TAG=latest
