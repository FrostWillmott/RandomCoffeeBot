# Random Coffee Bot Configuration
# Copy this file to .env and fill in your values

# Application Settings
# Set to true for development, false for production
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Secret key for application security
# MUST be changed in production! Generate a strong random string
SECRET_KEY=dev-secret-key-change-in-production

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram channel ID for announcements (optional)
# Leave empty if not using channel announcements
CHANNEL_ID=

# Database Configuration
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/randomcoffee

# PostgreSQL credentials (for Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=randomcoffee

# Redis Configuration
# Redis connection string for FSM storage
# Format: redis://host:port/db
REDIS_URL=redis://localhost:6379/0

# Health Check Configuration
# Path to heartbeat file for health checks (used by Docker)
HEALTHCHECK_HEARTBEAT_FILE=/tmp/healthy
